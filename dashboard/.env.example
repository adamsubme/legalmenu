# Mission Control - Environment Variables Template
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local with real secrets!

# Database
DATABASE_PATH=./mission-control.db
SESSION_SECRET=your-session-secret-here-min-32-chars

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
MISSION_CONTROL_ORIGIN=http://127.0.0.1:3000

# OpenAI
OPENAI_API_KEY=sk-proj-your-key-here

# Authentication
AUTH_USERNAME=your-admin-username
AUTH_PASSWORD=your-secure-password
MC_LOGIN_USER=admin@example.com
MC_LOGIN_PASSWORD=your-secure-password

# Notion Integration
NOTION_TOKEN=ntn_your-token-here
NOTION_TASK_DB=your-database-id-here

# Agent API
AGENT_API_KEY=your-agent-api-key
